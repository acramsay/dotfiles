{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["openrouter"],
  "formatter": {
    "dprint": {
      "command": ["dprint", "fmt", "--stdin", "md"],
      "extensions": [".md"]
    },
    "gopls": {
      "disabled": true
    },
    "gofumpt": {
      "command": ["gofumpt", "$FILE"],
      "extensions": [".go"]
    }
  },
  "lsp": {
    "golangci-lint": {
      "command": ["golangci-lint-langserver"],
      "extensions": [".go"],
      "initialization": {
        "command": ["golangci-lint", "run", "--output.json.path", "stdout", "--show-stats=false", "--issues-exit-code=1"]
      }
    }
  },
  "model": "xiaomi/mimo-v2-flash",
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "deny",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "go *": "allow",
      "go install *": "deny",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "sort": "allow",
      "task *": "allow",
      "wc *": "deny",
      "xargs *": "deny",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr comment *": "ask",
      "gh pr review *": "ask",
    },
    "external_directory": {
      "~/git/dotfiles/**": "allow",
      "~/.config/helix/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-mem"
  ]
}
