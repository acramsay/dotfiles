{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["anthropic","openrouter"],
  "formatter": {
    "dprint": {
      "command": ["dprint", "fmt", "--stdin", "md"],
      "extensions": [".md"]
    },
    "gopls": {
      "disabled": true
    },
    "gofumpt": {
      "command": ["gofumpt", "$FILE"],
      "extensions": [".go"]
    },
    "ruff": {
      "disabled": true
    }
  },
  "lsp": {
    "golangci-lint": {
      "command": ["golangci-lint-langserver"],
      "extensions": [".go"],
      "initialization": {
        "command": ["golangci-lint", "run", "--output.json.path", "stdout", "--show-stats=false", "--issues-exit-code=1"]
      }
    }
  },
  "model": "xiaomi/mimo-v2.5",
  "permission": {
    "bash": {
      "*": "ask",
      "npx ctx7 *": "allow",
      "npx ctx7@latest *": "allow",
      "ctx7 *": "allow",
      "git *": "ask",
      "git status *": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git branch *": "allow",
      "git remote -v *": "allow",
      "git remote show *": "allow",
      "git blame *": "allow",
      "git rev-parse *": "allow",
      "git describe *": "allow",
      "git tag --list *": "allow",
      "git tag -l *": "allow",
      "git ls-files *": "allow",
      "git ls-remote *": "allow",
      "git shortlog *": "allow",
      "git reflog *": "allow",
      "git stash list *": "allow",
      "git config --get *": "allow",
      "git config --list *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "go doc *": "allow",
      "go env *": "allow",
      "go version *": "allow",
      "go list *": "allow",
      "cargo --version": "allow",
      "cargo -V": "allow",
      "cargo doc *": "allow",
      "cargo test *": "allow",
      "cargo clippy *": "allow",
      "cargo fmt *": "allow",
      "cargo tree *": "allow",
      "cargo metadata *": "allow",
      "cargo search *": "allow",
      "cargo check *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "man *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "sort *": "allow",
      "pwd": "allow",
      "which *": "allow",
      "env": "allow",
      "date *": "allow",
      "whoami": "allow",
      "diff *": "allow",
      "cmp *": "allow",
      "basename *": "allow",
      "dirname *": "allow",
      "realpath *": "allow",
      "cut *": "allow",
      "uniq *": "allow",
      "column *": "allow",
      "nl *": "allow",
      "task *": "allow",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr checks *": "allow",
      "gh pr status": "allow",
      "gh issue view *": "allow",
      "gh issue list *": "allow",
      "gh issue status": "allow",
      "gh run view *": "allow",
      "gh run list *": "allow",
      "gh workflow view *": "allow",
      "gh workflow list *": "allow",
      "gh repo view *": "allow",
      "gh release view *": "allow",
      "gh release list *": "allow",
      "gh browse *": "allow",
      "gh search *": "allow",
      "gh label list *": "allow",
      "python *": "deny",
      "wc *": "deny",
      "xargs *": "deny",
    },
    "external_directory": {
      "~/git/dotfiles/**": "allow",
      "~/.config/helix/**": "allow",
      "~/.config/opencode/**": "allow"
    }
  },
  "plugin": [
    "@ex-machina/opencode-anthropic-auth",
    "@tarquinen/opencode-dcp@latest",
    "opencode-mem@2.13.0"
  ],
  "provider": {
    "openrouter": {
      "models": {
        "xiaomi/mimo-v2.5": {
          "name": "Xiaomi MiMo v2.5",
          "limit": {
            "context": 1048576,
            "output": 131072
          }
        }
      }
    }
  }
}
