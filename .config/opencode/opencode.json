{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "enabled_providers": ["anthropic", "github-copilot", "openrouter"],
  "formatter": {
    "dprint": {
      "command": ["dprint", "fmt", "--stdin", "md"],
      "extensions": [".md"],
    },
    "gopls": {
      "disabled": true,
    },
    "gofumpt": {
      "command": ["gofumpt", "$FILE"],
      "extensions": [".go"],
    }
  },
  "model": "xiaomi/mimo-v2-flash",
  "permission": {
    "bash": {
      "*": "ask",
      "az boards show *": "allow",
      "az boards query *": "allow",
      "az boards work-item query *": "allow",
      "az boards work-item show *": "allow",
      "git *": "deny",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "echo *": "allow",
      "go *": "allow",
      "go install *": "deny",
      "grep *": "allow",
      "head *": "allow",
      "jq *": "allow",
      "tail *": "allow",
      "tree *": "allow",
      "sort": "allow",
      "task *": "allow",
      "wc *": "deny",
      "xargs *": "deny",
      "gh pr view *": "allow",
      "gh pr diff *": "allow",
      "gh pr list *": "allow",
      "gh pr comment *": "ask",
      "gh pr review *": "ask",
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "question": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "skill": {
      "*": "allow"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
  ],
}
